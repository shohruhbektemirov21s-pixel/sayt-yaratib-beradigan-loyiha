# --- AI (Google Gemini tavsiya) ---
AI_PROVIDER=google
GOOGLE_GENERATIVE_AI_API_KEY=
# Model: https://ai.google.dev/gemini-api/docs/models
GOOGLE_GENERATIVE_AI_MODEL=gemini-2.0-flash
# GOOGLE_GENERATIVE_AI_BASE_URL=https://generativelanguage.googleapis.com

# OpenAI / DeepSeek (ixtiyoriy, AI_PROVIDER=openai|deepseek bo‘lsa)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# --- Builder (sayt generatsiyasi) ---
# Default: mehmon rejimi — AI APIlar kirishsiz ishlaydi (IP bo‘yicha rate limit).
# Korporativ: true qilib qo‘ying — faqat builder/admin sessiyasi bilan.
# REQUIRE_BUILDER_AI_LOGIN=true
# Mehmon limiti: har IP uchun daqiqada maksimal AI so‘rov (default 40)
# WEBSITE_AI_RATE_LIMIT_PER_MINUTE=40
# Muhim: haqiqiy parol qo‘ying. Foydalanuvchi /[locale]/builder-login orqali kiradi.
BUILDER_PASSWORD=change-me-builder-password
# "false" bo‘lsa — veb ro‘yxatdan o‘tish o‘chadi (default: yoqilgan).
# BUILDER_SELF_REGISTRATION_ENABLED=false
# Dev: parol tiklash javobida reset havolasini qaytarish (ishlab chiqarishda yoqmang).
# PASSWORD_RESET_DEV_LEAK=true
# Sessiya imzosi (32+ tasodifiy belgi)
BUILDER_SESSION_SECRET=random-32-chars-minimum-change-me-builder
# Cookie ichidagi tarif: basic | pro | premium (Pro/Premium → 5 sahifa + Gallery)
BUILDER_PLAN_TIER=basic
# ISO sana (masalan 2026-12-31) — Dashboardda ko‘rsatiladi
# BUILDER_SUBSCRIPTION_UNTIL=2026-12-31

# Admin AI uchun sxema rejasi (default: pro)
ADMIN_AI_PLAN_TIER=pro

# Faqat lokal test / CI: true bo‘lsa rate limit va majburiy kirish ham o‘chadi (faqat dev)
# ALLOW_AI_WITHOUT_LOGIN=true

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ai_website_builder?schema=public"
# Agar `npx prisma migrate deploy` → P3005 (baza bo‘sh emas) chiqsa: lokal uchun `npm run db:push`
# yoki bo‘sh bazada `npm run db:migrate` (Prisma hujjatlari: migrate baseline).

# Telegram bot (grammy) — tokenni faqat mahalliy .env da saqlang (repo ga qo‘ymang)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
# Mini App HTTPS URL (masalan https://domen.uz/miniapp)
TELEGRAM_WEBAPP_URL=
# Mini App cookie imzosi (32+ tasodifiy)
MINIAPP_SESSION_SECRET=
# Telegram Stars / to‘lov (ixtiyoriy)
# TELEGRAM_PROVIDER_TOKEN=

# Mini App / metadata — local dev
# NEXT_PUBLIC_DEV_PORT=3001
# NEXT_PUBLIC_APP_URL=http://localhost:3001
# APP_BASE_URL=http://localhost:3001

# Admin panel (/[locale]/admin) — faqat URL orqali
# ADMIN_USERNAME bo‘sh bo‘lmasa, kirishda login + parol so‘raladi.
ADMIN_USERNAME=
ADMIN_PASSWORD=change-me-strong
ADMIN_SESSION_SECRET=random-32-chars-minimum-change-me
# Audit log / managed subscription “granted by” label (e.g. ops email). Falls back to admin:cookie-session.
# ADMIN_AUDIT_ACTOR=ops@example.com

# --- Payme (checkout + Merchant API webhook: POST /api/payments/payme) ---
# Kabinet: Endpoint URL → https://<domen>/api/payments/payme
# Hisob (Account) kalitlari: user_id, plan, months (checkout URL va webhook tekshiruvi bilan mos)
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=
# USD jadval → so‘m: 1 USD necha so‘m (default 12500)
PAYME_USD_TO_UZS_RATE=12500
# Test: https://checkout.test.paycom.uz
# PAYME_CHECKOUT_BASE=https://checkout.paycom.uz

# --- Qo‘lda to‘lov cheklari (EXIF + Gemini Vision OCR) ---
# Chekda qidiriladigan telefon (faqat raqamlar, masalan 998501093514 yoki +998... dan keyingi 12 raqam)
RECEIPT_EXPECTED_MSISDN=
# Payme izoh prefiksi + 4 raqam (masalan Usta-7782)
RECEIPT_PAYMENT_NOTE_PREFIX=Usta
RECEIPT_CODE_TTL_HOURS=72
# Pillow EXIF: Kali/Debian da tizim `pip` PEP668 bilan bloklanadi — loyiha ichida venv:
#   npm run receipts:venv
# Keyin:
# Pillow EXIF (scripts/receipt_exif_pillow.py). Bo‘sh qoldirilsa yoqilgan hisoblanadi; o‘chirish: RECEIPT_USE_PILLOW_EXIF=0
# RECEIPT_USE_PILLOW_EXIF=0
# RECEIPT_EXIF_PYTHON_BIN=.venv-receipts/bin/python3
