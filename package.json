{
  "name": "ai-website-builder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "build:clean": "npm run clean && npm run build",
    "dev": "node scripts/next-dev-port.mjs",
    "dev:turbo": "npm run clean && node scripts/next-dev-port.mjs --turbo",
    "dev:webpack": "node scripts/next-dev-port.mjs",
    "dev:clean": "npm run clean && npm run dev",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/next/dist/bin/next lint",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "receipts:venv": "python3 -m venv .venv-receipts && .venv-receipts/bin/pip install -U pip && .venv-receipts/bin/pip install -r requirements-receipts.txt",
    "telegram:dev": "tsx --conditions react-server --env-file=.env scripts/telegram-dev.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@grammyjs/conversations": "^1.2.0",
    "@prisma/client": "^5.22.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exifr": "^7.1.3",
    "framer-motion": "^11.15.0",
    "grammy": "^1.31.3",
    "jsonrepair": "^3.13.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.469.0",
    "next": "14.2.35",
    "next-intl": "^3.26.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.16",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
